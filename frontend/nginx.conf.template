server {
    listen ${PORT};
    root /app;
    index index.html;

    # Agent discovery headers on ALL responses
    add_header X-API-Base "/api" always;
    add_header Link '</.well-known/agent.json>; rel="agent-manifest", </api/openapi.json>; rel="service-desc"' always;

    # Content negotiation on root URL
    # Agent sends Accept: application/json → gets discovery JSON
    # Browser sends Accept: text/html,application/xhtml+xml,... → gets SPA (never matches)
    location = / {
        if ($http_accept ~* "application/json") {
            rewrite ^ /.well-known/agent.json last;
        }
        try_files /index.html =404;
    }

    # Serve .well-known files directly as JSON (NOT SPA fallback)
    location /.well-known/ {
        default_type application/json;
        try_files $uri =404;
    }

    # Serve robots.txt directly
    location = /robots.txt {
        try_files $uri =404;
    }

    # Serve static assets directly
    location /assets/ { try_files $uri =404; }
    location /logos/ { try_files $uri =404; }
    location = /favicon.svg { try_files $uri =404; }

    # SPA fallback — all other routes serve index.html
    location / {
        try_files $uri /index.html;
    }

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml;
    gzip_min_length 256;
}
